<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #eeeeee; -fx-border-width: 0 0 1 0;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SellerProductController">

    <!-- Product Image Image Holder Container -->
    <StackPane style="-fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 2;">
        <ImageView fx:id="imgProduct" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="false">
            <Image url="@../../images/placeholder.png" />
        </ImageView>
    </StackPane>

    <!-- ===== PRODUCT INFO DETAILS ===== -->
    <VBox spacing="8.0" HBox.hgrow="ALWAYS">
        <Label fx:id="lblProductName" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1f2933;" text="Product Name" wrapText="true" />

        <VBox spacing="3.0">
            <HBox spacing="5">
                <Label style="-fx-text-fill: #777; -fx-font-size: 12px;" text="Session ID:" />
                <Label fx:id="lblSessionID" style="-fx-font-family: 'Monospaced'; -fx-text-fill: #34495e;" text="PH-999-LONG-ID-EXAMPLE" />
            </HBox>
            <HBox spacing="5">
                <Label style="-fx-text-fill: #777; -fx-font-size: 12px;" text="Product Type:" />
                <Label fx:id="lblProductType" style="-fx-font-style: italic; -fx-text-fill: #555;" text="Electronics / Smartphones" />
            </HBox>
        </VBox>

        <Separator prefWidth="200.0" />

        <!-- ===== PRICES AND VALUATIONS ===== -->
        <VBox spacing="5.0">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label minWidth="110.0" style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Starting Price:" />
                <Label fx:id="lblStartingPrice" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 14px;" text="0 $" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label minWidth="110.0" style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Current Price:" />
                <Label fx:id="lblCurrentPrice" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 14px;" text="0 $" />
            </HBox>
        </VBox>
    </VBox>

    <!-- ===== ACTIONS & STATUS TAGS ===== -->
    <VBox alignment="TOP_RIGHT" minWidth="180.0" spacing="15.0">
        <!-- Time Remaining Countdown / Ended Date Block -->
        <VBox alignment="TOP_RIGHT" spacing="5">
            <Label fx:id="lblTimeHeader" style="-fx-font-size: 10px; -fx-text-fill: #999;" text="Time Remaining:" />
            <Label fx:id="lblTimeRemaining" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="02h 45m 10s" />
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <!-- View Detail Button Execution -->
        <Button fx:id="btnGoDetail" mnemonicParsing="false" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="VIEW DETAIL" />

        <!-- Status Pill Element -->
        <Label fx:id="lblStatusTag" style="-fx-font-size: 11px; -fx-padding: 4 12; -fx-background-color: #e8f5e9; -fx-text-fill: #2e7d32; -fx-background-radius: 20; -fx-font-weight: bold;" text="RUNNING" />
    </VBox>
</HBox>
