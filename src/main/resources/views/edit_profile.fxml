<?xml version="1.0" encoding="UTF-8"?>

<!--
  File: EditProfile.fxml
  Concept: Midnight Blue (#2c3e50) | Pure Flat Minimalist | Synchronized with Profile Main
-->

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="580.0" prefWidth="380.0" style="-fx-background-color: #ecf0f1; -fx-font-family: 'System';" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.EditProfileController">

    <!-- ===== HEADER (Đồng bộ tuyệt đối với Main Profile) ===== -->
    <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50; -fx-padding: 0 25;">
        <Label text="👤 Edit Profile" textFill="WHITE">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
    </HBox>

    <!-- ===== BODY CONTENT ===== -->
    <VBox alignment="TOP_CENTER" spacing="0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="30" left="35" right="35" top="25" />
        </padding>

        <!-- ===== AVATAR SELECTION AREA (Đồng bộ khung tròn với Main) ===== -->
        <VBox alignment="CENTER" spacing="10">
            <StackPane fx:id="avatarPane" maxHeight="110.0" maxWidth="110.0" onMouseClicked="#handleChangeAvatar" prefHeight="110.0" prefWidth="110.0" style="-fx-cursor: hand; -fx-background-color: #34495e; -fx-background-radius: 55; -fx-border-color: #bdc3c7; -fx-border-radius: 55; -fx-border-width: 2;">
                <children>
                    <!-- Label mặc định khi chưa có ảnh -->
                    <Label text="?" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="38.0" />
                        </font>
                    </Label>

                    <!-- Image View được cắt tròn trùng khớp tỉ lệ -->
                    <ImageView fx:id="avatarImageView" fitHeight="106.0" fitWidth="106.0" pickOnBounds="true" preserveRatio="false">
                        <clip>
                            <Circle centerX="53.0" centerY="53.0" radius="53.0" />
                        </clip>
                    </ImageView>

                    <!-- Lớp phủ chữ CHANGE cắt tròn tinh tế -->
                    <VBox alignment="CENTER" style="-fx-background-color: rgba(44, 62, 80, 0.65);">
                        <clip>
                            <Circle centerX="53.0" centerY="53.0" radius="53.0" />
                        </clip>
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="CHANGE" />
                    </VBox>
                </children>
            </StackPane>
            <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" text="Click to change photo" />
        </VBox>

        <!-- Khoảng đệm giữa Avatar và Form nhập liệu -->
        <Region prefHeight="15.0" VBox.vgrow="ALWAYS" />

        <!-- ===== INPUT FORM FIELDS ===== -->
        <VBox alignment="CENTER" fillWidth="true" spacing="12">

            <!-- Full Name Field -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" text="Full Name" />
                <TextField fx:id="txtFullName" prefHeight="40" promptText="Enter your full name" style="-fx-background-color: #ffffff; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 0 12; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" />
            </VBox>

            <!-- Username Field -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" text="Username" />
                <TextField fx:id="txtUsername" prefHeight="40" promptText="Enter username" style="-fx-background-color: #ffffff; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 0 12; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" />
            </VBox>

            <!-- New Password Field -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" text="New Password" />
                <PasswordField fx:id="txtPassword" prefHeight="40" promptText="Leave blank to keep current" style="-fx-background-color: #ffffff; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 0 12; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" />
            </VBox>

            <!-- Nhãn thông báo lỗi phẳng -->
            <Label fx:id="errorLabel" managed="false" style="-fx-font-size: 12px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;" visible="false">
                <VBox.margin>
                    <Insets top="2.0" />
                </VBox.margin>
            </Label>

        </VBox>

        <!-- Đẩy cụm nút chức năng xuống dưới đáy một cách cân đối -->
        <Region prefHeight="20.0" VBox.vgrow="ALWAYS" />

        <!-- ===== ACTION BUTTONS ===== -->
        <HBox alignment="CENTER" spacing="15">
            <!-- Nút Cancel màu xám khói chuẩn nút phụ -->
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCancel" prefHeight="42.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 13px;" text="Cancel" HBox.hgrow="ALWAYS" />

            <!-- Nút Save Changes màu xanh lục Emerald đồng bộ nút kích hoạt của Main -->
            <Button fx:id="btnSave" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleSave" prefHeight="42.0" style="-fx-background-color: #27ae60; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 13px;" text="Save Changes" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>
</VBox>