<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="TOP_CENTER" spacing="24" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.EditProfileController">

    <padding>
        <Insets bottom="32" left="32" right="32" top="32" />
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';" text="Edit Profile" />

    <VBox alignment="CENTER" spacing="10">
        <StackPane fx:id="avatarPane" onMouseClicked="#handleChangeAvatar"
                   prefHeight="100.0" prefWidth="100.0" maxWidth="100.0" maxHeight="100.0"
                   style="-fx-cursor: hand; -fx-background-color: #dee2e6;">
            <clip>
                <Circle centerX="50.0" centerY="50.0" radius="50.0" />
            </clip>
            <children>
                <ImageView fx:id="avatarImageView" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="false" />

                <VBox alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.4);">
                    <Label text="Change" textFill="WHITE" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';" />
                </VBox>
            </children>
        </StackPane>
        <Label text="Click to change photo" style="-fx-text-fill: #95a5a6; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';" />
    </VBox>

    <VBox spacing="16" maxWidth="350" alignment="CENTER">

        <VBox spacing="6">
            <Label text="Full Name" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;" />
            <TextField fx:id="txtFullName" prefHeight="38" promptText="Enter your full name"
                       style="-fx-background-color: white; -fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 10;" />
        </VBox>

        <VBox spacing="6">
            <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;" />
            <TextField fx:id="txtUsername" prefHeight="38" promptText="Enter username"
                       style="-fx-background-color: white; -fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 10;" />
        </VBox>

        <VBox spacing="6">
            <Label text="New Password" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;" />
            <PasswordField fx:id="txtPassword" prefHeight="38" promptText="Leave blank to keep current"
                           style="-fx-background-color: white; -fx-border-color: #dee2e6; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 10;" />
        </VBox>

    </VBox>

    <Label fx:id="errorLabel" textFill="#e74c3c" visible="false" managed="false" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12px;" />

    <HBox alignment="CENTER" spacing="12">
        <Button onAction="#handleCancel" prefWidth="110" prefHeight="38" text="Cancel"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />

        <Button fx:id="btnSave" onAction="#handleSave" prefWidth="130" prefHeight="38" text="Save Changes"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
    </HBox>

</VBox>