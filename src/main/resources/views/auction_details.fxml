<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.LineChart?>
<GridPane prefHeight="700.0" prefWidth="1050.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionDetailController">

    <columnConstraints>
        <ColumnConstraints percentWidth="50.0" />
        <ColumnConstraints percentWidth="50.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints vgrow="ALWAYS" />
    </rowConstraints>

    <children>

        <!-- ============ LEFT PANEL ============ -->
        <VBox spacing="15.0" style="-fx-border-color: #dee2e6; -fx-border-width: 0 1 0 0;" GridPane.columnIndex="0">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

            <!-- Header row: Back + title + timer -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button fx:id="btnBack" onAction="#handleBack" style="-fx-background-color: #6c757d; -fx-text-fill: white;" text="← Back" />
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Auction Detail" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTimer" style="-fx-font-family: monospace; -fx-font-size: 16px; -fx-text-fill: #27ae60;                               -fx-background-color: #eafaf1; -fx-padding: 5 10;                               -fx-border-color: #27ae60; -fx-border-radius: 5;" text="00:00:00" />
            </HBox>

            <!-- Category + Name + Description -->
            <VBox spacing="5">
                <Label fx:id="lblCategory" style="-fx-text-fill: #27ae60; -fx-font-weight: bold;" text="CATEGORY" />
                <Label fx:id="lblName" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Product Name" wrapText="true" />
                <Text fx:id="txtDescription" fill="#555" text="Description..." wrappingWidth="400.0" />
            </VBox>

            <!-- Seller + Starting price -->
            <HBox spacing="40">
                <VBox>
                    <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="SELLER" />
                    <Label fx:id="lblSeller" style="-fx-font-weight: bold;" text="Unknown" />
                </VBox>
                <VBox>
                    <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="STARTING PRICE" />
                    <Label fx:id="lblStartingPrice" style="-fx-font-weight: bold;" text="\$0" />
                </VBox>
            </HBox>

            <Separator />

            <!-- Dynamic specs (Brand / Model / Artist depending on type) -->
            <GridPane fx:id="gridSpecs" hgap="15" vgap="8" />

            <!-- Current highest bid -->
            <VBox spacing="5">
                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" text="CURRENT HIGHEST BID" />
                <Label fx:id="lblCurrentBid" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="\$0" />
                <Label fx:id="lblLeadingUser" style="-fx-font-weight: bold;" text="Leading: No bids yet" />
            </VBox>

            <!-- Bid input box -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20;
                                  -fx-border-color: #ddd; -fx-border-radius: 8;">
                <Label style="-fx-font-weight: bold;" text="Place your bid" />

                <TextField fx:id="txtBidAmount"
                           prefHeight="35.0"
                           promptText="Enter amount (e.g. 1500)" />

                <Label fx:id="lblMinBidHint"
                       style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"
                       text="Min next bid: $10" />

                <HBox spacing="10">
                    <Button fx:id="btnPlaceBid"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            onAction="#handlePlaceBid"
                            prefHeight="38.0"
                            style="-fx-background-color: #27ae60;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;"
                            text="Place Bid" />

                    <Button fx:id="btnAutoBid"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            onAction="#handleAutoBid"
                            prefHeight="38.0"
                            style="-fx-background-color: #f39c12;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;"
                            text="AutoBid" />
                </HBox>
            </VBox>

            <!-- Balance display -->
            <VBox spacing="8"
                  style="-fx-background-color: #FFFFFF;
             -fx-padding: 15;
             -fx-background-radius: 8;">

                <VBox spacing="3">
                    <Label style="-fx-font-size: 11px;
                       -fx-text-fill: #bdc3c7;"
                           text="AVAILABLE BALANCE" />

                    <Label fx:id="lblAvailableBalance"
                           style="-fx-font-size: 18px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #2ecc71;"
                           text="\$0.00" />
                </VBox>

            </VBox>
        </VBox>

        <!-- ============ RIGHT PANEL – Bid History + Price Chart ============ -->
        <VBox spacing="15.0" style="-fx-background-color: white;" GridPane.columnIndex="1">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Bid History" />
                <Label style="-fx-background-color: #27ae60; -fx-text-fill: white;
                              -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 11px;" text="RECENT" />
            </HBox>

            <ListView fx:id="lvBidHistory"
                      prefHeight="250.0"
                      style="-fx-background-insets: 0; -fx-font-family: 'Courier New'; -fx-font-size: 13px;"
                      VBox.vgrow="SOMETIMES"/>

            <!-- Price curve chart -->
            <VBox spacing="6">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Price Curve" />
                    <Label style="-fx-background-color: #3498db; -fx-text-fill: white;
                                  -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 11px;" text="REALTIME" />
                </HBox>

                <LineChart fx:id="bidPriceChart"
                           animated="false"
                           prefHeight="220.0"
                           style="-fx-background-color: transparent;"
                           VBox.vgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis label="Time" tickLabelRotation="45" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Price ($)" forceZeroInRange="false" />
                    </yAxis>
                </LineChart>
            </VBox>

        </VBox>
    </children>
</GridPane>
