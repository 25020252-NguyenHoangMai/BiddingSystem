<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="15.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SessionHistoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Button fx:id="btnBack" mnemonicParsing="false" style="-fx-background-radius: 20; -fx-cursor: hand;" text="← Back to Profile" />

        <Label text="Joined Session History">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="10.0">

            <MenuButton fx:id="menuItemType" mnemonicParsing="false" prefWidth="140.0" text="All Types"
                        style="-fx-background-color: white; -fx-border-color: #ccc; -fx-background-radius: 5; -fx-border-radius: 5; -fx-cursor: hand;">
                <items>
                    <MenuItem text="All Types" />
                    <MenuItem text="Electronics" />
                    <MenuItem text="Fashion" />
                    <MenuItem text="Home &amp; Garden" />
                    <MenuItem text="Collectibles" />
                    <MenuItem text="Others" />
                </items>
            </MenuButton>

            <HBox alignment="CENTER_RIGHT" spacing="0.0">
                <TextField fx:id="txtSearch" prefWidth="250.0" promptText="Search by ID, Product, Seller..."
                           style="-fx-background-radius: 15 0 0 15; -fx-border-color: #ccc; -fx-border-radius: 15 0 0 15;" />
                <Button fx:id="btnSearch" mnemonicParsing="false" prefHeight="27.0"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 0 15 15 0; -fx-cursor: hand;" text="🔍 Search">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
            </HBox>
        </HBox>
    </HBox>

    <Separator />

    <HBox alignment="CENTER_LEFT">
        <MenuButton fx:id="menuFilter" mnemonicParsing="false" prefWidth="200.0" text="All Sessions"
                    style="-fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 5; -fx-cursor: hand;">
            <items>
                <MenuItem fx:id="itemAll" text="All Sessions" />
                <MenuItem fx:id="itemActive" text="Active Sessions" />
                <MenuItem fx:id="itemWon" text="Won Sessions" />
                <MenuItem fx:id="itemDeleted" text="Deleted Sessions" />
            </items>
        </MenuButton>
    </HBox>

    <ListView fx:id="listSessions" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-background-color: transparent;" />
</VBox>