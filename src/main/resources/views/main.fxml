<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="650.0" prefWidth="1000.0" stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 12 25;">
        <Label fx:id="welcomeLabel" text="Welcome, Guest" textFill="WHITE">
            <font><Font name="System Bold" size="18.0" /></font>
        </Label>

        <Button onAction="#handleViewProfile" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand; -fx-border-color: #7f8c8d; -fx-border-radius: 5; -fx-background-radius: 5;" text="👤 Profile">
            <font><Font name="System" size="13.0" /></font>
        </Button>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="8"
              onMouseClicked="#handleDepositBalance"
              style="-fx-background-color: #1a252f; -fx-padding: 5 15; -fx-background-radius: 20; -fx-cursor: hand;">
            <Label text="💰" />
            <Label fx:id="balanceLabel" text="Balance: 0$" textFill="#f1c40f">
                <font><Font name="System Bold" size="15.0" /></font>
            </Label>
            <Label text="＋" textFill="#f1c40f" style="-fx-font-size: 13px; -fx-opacity: 0.75;" />
        </HBox>

        <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Log out" />
    </HBox>

    <VBox spacing="20" style="-fx-padding: 25;" VBox.vgrow="ALWAYS">

        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox>
                <Label text="Current Auctions">
                    <font><Font name="System Bold" size="26.0" /></font>
                </Label>
                <Label text="Discover and bid on your favorite items" textFill="#7f8c8d" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5 10;">
                <Label text="🔍" textFill="#7f8c8d" />
                <TextField fx:id="searchField" prefHeight="20.0" prefWidth="350.0" promptText="Search by Product Name, Seller, or ID..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent;" />
                <Button onAction="#handleSearch" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Search" />
            </HBox>
        </HBox>

        <TableView fx:id="tableAuctions" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-overflow-x: hidden;" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colProductName" prefWidth="300" text="Product Name" />
                <TableColumn fx:id="colCurrentPrice" prefWidth="150" text="Current Price ($)" />
                <TableColumn fx:id="colSeller" prefWidth="150" text="Seller" />
                <TableColumn fx:id="colTime" prefWidth="150" text="Time Left" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15">

            <Button fx:id="addBtn" managed="true" onAction="#handleAddProduct" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="➕ Add Product" visible="true" />
        </HBox>
    </VBox>
</VBox>
