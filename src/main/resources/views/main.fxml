<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
        <Label fx:id="welcomeLabel" text="Welcome, Guest" textFill="WHITE">
            <font><Font name="System Bold" size="16.0" /></font>
        </Label>

        <Region HBox.hgrow="ALWAYS" />

        <Label fx:id="balanceLabel" text="Balance: 0$" textFill="#f1c40f">
            <font><Font name="System Bold" size="16.0" /></font>
        </Label>

        <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-cursor: hand;" text="Log out" textFill="WHITE" />
    </HBox>

    <VBox spacing="15" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
        <Label text="Current Auctions">
            <font><Font name="System Bold" size="22.0" /></font>
        </Label>

        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colName" prefWidth="250" text="Product Name" />
                <TableColumn fx:id="colPrice" prefWidth="150" text="Current Price ($)" />
                <TableColumn fx:id="colSeller" prefWidth="150" text="Seller" />
                <TableColumn fx:id="colTime" prefWidth="150" text="Time Left" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Button fx:id="addBtn" managed="true" onAction="#handleAddProduct" prefHeight="35.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Add Product" visible="true" />

            <Button onAction="#handleRefresh" prefHeight="35.0" prefWidth="120.0" style="-fx-cursor: hand;" text="Refresh List" />
        </HBox>
    </VBox>
</VBox>
