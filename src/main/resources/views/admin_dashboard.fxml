<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="750.0" prefWidth="1200.0" spacing="0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" style="-fx-background-color: #2c3e50; -fx-padding: 0 25 0 25;">
            <children>
                <Label style="-fx-font-size: 22; -fx-text-fill: white; -fx-font-weight: bold;" text="ADMIN" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblAdminStatus" style="-fx-text-fill: #2ecc71;" />
                <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 18 8 18; -fx-cursor: hand;" text="Đăng xuất">
                    <HBox.margin>
                        <Insets left="20" />
                    </HBox.margin>
               <font>
                  <Font size="13.0" />
               </font>
                </Button>
            </children>
        </HBox>

        <TabPane style="-fx-tab-closing-policy: UNAVAILABLE;" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Quản lý Sản phẩm">
                    <content>
                        <VBox VBox.vgrow="ALWAYS">
                            <VBox spacing="15"
                                  style="-fx-padding: 15;"
                                  VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8;">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Tìm kiếm SP:" />
                                                <TextField fx:id="txtSearchItem" prefWidth="300.0" promptText="Nhập tên sản phẩm..." style="-fx-background-radius: 15;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnDeleteItem" onAction="#handleDeleteItem" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18 8 18; -fx-cursor: hand; " text="XÓA MỤC ĐÃ TÍCH" />
                                            </children>
                                        </HBox>
                                        <TableView fx:id="itemTable" editable="true" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colItemSelect" maxWidth="50.0" minWidth="50.0" prefWidth="50.0" resizable="false" text="✔" />
                                                <TableColumn fx:id="colItemId" prefWidth="250.0" text="ID" />
                                                <TableColumn fx:id="colItemName" prefWidth="600.0" text="Tên sản phẩm" />
                                                <TableColumn fx:id="colItemSeller" prefWidth="250.0" text="Người bán" />
                                                <TableColumn fx:id="colItemView" prefWidth="220.0" minWidth="220.0" style="-fx-alignment: CENTER;" text="Chi tiết" />
                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Quản lý Người dùng">
                    <content>
                        <VBox VBox.vgrow="ALWAYS">
                            <VBox spacing="15"
                                  style="-fx-padding: 15;"
                                  VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 8;">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Tìm kiếm User:" />
                                                <TextField fx:id="txtSearchUser" prefWidth="300.0" promptText="Nhập tên người dùng..." style="-fx-background-radius: 15;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnDeleteUser" onAction="#handleDeleteUser" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="XÓA USER ĐÃ TÍCH" />
                                            </children>
                                        </HBox>
                                        <TableView fx:id="userTable" editable="true" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colUserSelect" maxWidth="40.0" minWidth="40.0" prefWidth="40.0" resizable="false" text="✔" />
                                                <TableColumn fx:id="colUserId" prefWidth="350.0" text="ID User" />
                                                <TableColumn fx:id="colUsername" prefWidth="300.0" style="-fx-alignment: CENTER;" text="Tên đăng nhập" />
                                                <TableColumn fx:id="colFullName" prefWidth="500.0" style="-fx-alignment: CENTER;" text="Tên người dùng" />

                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>
