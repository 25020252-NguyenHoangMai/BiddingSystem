<?xml version="1.0" encoding="UTF-8"?>

<!--
  File: SellerHistory.fxml
  Concept: Midnight Blue (#2c3e50) | Flat Minimalist Design | No Emoji | Static Font Sizing
-->

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #ecf0f1; -fx-font-family: 'System';" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SellerHistoryController">

    <!-- ===== HEADER (Đồng bộ 100% Midnight Blue với hệ thống) ===== -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 12 25;">
        <!-- Nút Back phẳng, bo góc 5px đồng bộ với nút Profile ở Main -->
        <Button fx:id="btnBack" mnemonicParsing="false" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand; -fx-border-color: #7f8c8d; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold; -fx-font-size: 13px;" text="← Back to Profile" />

        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #ffffff;" text="My Listed Products" />

        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- ===== MAIN BODY CONTENT ===== -->
    <VBox spacing="20.0" style="-fx-padding: 25;" VBox.vgrow="ALWAYS">

        <!-- Thanh công cụ: Bộ lọc và Ô tìm kiếm dàn phẳng -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">

            <!-- Bộ lọc Trạng thái phiên (Status) -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2c3e50;" text="Status:" />
                <MenuButton fx:id="menuFilterStatus" prefHeight="32.0" prefWidth="160.0" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" text="All Statuses" />
            </HBox>

            <Label style="-fx-font-size: 18px; -fx-text-fill: #cbd5e1;" text="|" />

            <!-- Bộ lọc Danh mục sản phẩm (Category) -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #2c3e50;" text="Category:" />
                <MenuButton fx:id="menuItemType" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 13px;" text="All Categories" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Ô tìm kiếm phẳng cấu trúc rỗng nền trắng giống hệt màn hình chính -->
            <HBox alignment="CENTER_LEFT" spacing="0.0" style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 2 2 2 10;">
                <TextField fx:id="txtSearch" prefHeight="28.0" prefWidth="280.0" promptText="Search by ID, Product Name..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-focus-color: transparent;" />
                <Button fx:id="btnSearch" mnemonicParsing="false" prefHeight="28.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand; -fx-font-size: 12px; -fx-alignment: CENTER;" text="Search" />
            </HBox>
        </HBox>

        <!-- Danh sách hiển thị các sản phẩm đăng bán của người dùng -->
        <ListView fx:id="listProducts" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-background-color: #ffffff;" VBox.vgrow="ALWAYS" />

    </VBox>
</VBox>