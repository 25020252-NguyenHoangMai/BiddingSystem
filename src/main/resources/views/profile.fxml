<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ProfileController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- ===== USER INFO ===== -->
    <VBox alignment="CENTER" spacing="10">
        <Circle fill="#d3d3d3" radius="45" />

        <Label fx:id="fullNameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Full Name" />

        <Label fx:id="usernameLabel" style="-fx-text-fill: gray;" text="\@username" />
    </VBox>

    <!-- ===== STATISTICS ===== -->
    <HBox alignment="CENTER" spacing="20">

        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
            <Label text="Total Bids" />
            <Label fx:id="totalBidsLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="0" />
        </VBox>

        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
            <Label text="Items Won" />
            <Label fx:id="itemsWonLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="0" />
        </VBox>

        <VBox fx:id="activeListingsBox" alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
            <Label text="Active Listings" />
            <Label fx:id="activeListingsLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="0" />
        </VBox>

    </HBox>

    <!-- ===== ACTION BUTTONS ===== -->
    <VBox alignment="CENTER" maxWidth="200" spacing="10">

        <Button maxWidth="Infinity" onAction="#handleEditProfile" text="Edit Profile" />

        <Button maxWidth="Infinity" onAction="#handleTransactionHistory" text="Transaction History" />

        <Button maxWidth="Infinity" onAction="#handleEnableSeller" style="-fx-background-color: #27ae60;" text="Enable Seller" textFill="WHITE" />

        <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: red; -fx-text-fill: white;" text="Logout" />

    </VBox>

</VBox>
