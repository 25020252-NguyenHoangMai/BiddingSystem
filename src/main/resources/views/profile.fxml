<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="TOP_CENTER" prefHeight="546.0" prefWidth="317.0" spacing="24" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ProfileController">

    <padding>
        <Insets bottom="32" left="32" right="32" top="32" />
    </padding>

    <!-- Tiêu đề bổ sung để cân bằng độ cao khung giống màn hình Edit Profile -->
    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';" text="My Profile" />

    <!-- ===== AVATAR & USER INFO ===== -->
    <VBox alignment="CENTER" spacing="10">

        <StackPane fx:id="avatarPane" maxHeight="100.0" maxWidth="100.0" onMouseClicked="#handleEditProfile" prefHeight="100.0" prefWidth="100.0" style="-fx-cursor: hand;" styleClass="avatar-container">
            <children>
                <Label fx:id="avatarLabel" styleClass="avatar-label" text="?" />

                <ImageView fx:id="avatarImageView" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="false">
                    <clip>
                        <Circle centerX="50.0" centerY="50.0" radius="50.0" />
                    </clip>
                </ImageView>
            </children>
        </StackPane>

        <Label fx:id="fullNameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';" text="Full Name" />
        <Label fx:id="usernameLabel" style="-fx-text-fill: #95a5a6; -fx-font-family: 'Segoe UI';" text="\@username" />
    </VBox>

    <!-- ===== ACTION BUTTONS ===== -->
    <!-- maxWidth đặt bằng 350 để khung căn chỉnh rộng bằng form Edit Profile -->
    <VBox alignment="CENTER" fillWidth="true" maxWidth="350" spacing="12">

        <Button maxWidth="Infinity" onAction="#handleEditProfile" prefHeight="38" style="-fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-family: 'Segoe UI';" text="Edit Profile" />

        <Button maxWidth="Infinity" onAction="#handleSessionHistory" prefHeight="38" style="-fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-family: 'Segoe UI';" text="Session History" />

        <Button fx:id="btnEnableSeller" maxWidth="Infinity" onAction="#handleEnableSeller" prefHeight="38" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-family: 'Segoe UI';" text="Enable Seller" />

        <Button maxWidth="Infinity" onAction="#handleLogout" prefHeight="38" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-family: 'Segoe UI';" text="Log out" />

    </VBox>

</VBox>
